# 관리자 초기 계정 (최초 시드 시 사용, 로그인 후 반드시 변경)
ADMIN_USERNAME="admin"
ADMIN_INITIAL_PASSWORD="kns2026!admin"

# 구글 시트 + 자동 응답메일 연동 (Google Apps Script 웹앱 URL)
# 설정 방법: docs/구글시트-연동-가이드.md 참조
